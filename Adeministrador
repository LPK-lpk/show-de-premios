<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bingo — Administração de Acesso</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/2.47.0/iconfont/tabler-icons.min.css">
<style>
  :root { --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #050505; font-family: var(--font); color: #fff; min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 2rem 1rem; }
  .logo { font-size: 13px; color: #444; margin-bottom: 2rem; letter-spacing: 0.1em; text-transform: uppercase; }
  #adminLogin { width: 100%; max-width: 400px; }
  #adminLogin h1 { font-size: 22px; font-weight: 600; color: #ccc; margin-bottom: 0.5rem; }
  #adminLogin p { font-size: 13px; color: #555; margin-bottom: 1.6rem; }
  #adminPanel { width: 100%; max-width: 720px; display: none; flex-direction: column; gap: 1.2rem; }
  .card { background: #080808; border: 1px solid #1a1a1a; border-radius: 12px; padding: 1.4rem; }
  .card-title { font-size: 15px; font-weight: 600; color: #ccc; margin-bottom: 1rem; display: flex; align-items: center; gap: 8px; }
  .field-group { display: flex; flex-direction: column; gap: 10px; }
  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  label { font-size: 11px; color: #555; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; display: block; }
  input[type=text], input[type=password], input[type=tel] { width: 100%; padding: 10px 12px; background: #131313; border: 1px solid #2a2a2a; border-radius: 8px; color: #fff; font-size: 14px; font-family: var(--font); outline: none; }
  input:focus { border-color: #444; }
  input::placeholder { color: #333; }
  input.err { border-color: #7f1d1d !important; }
  .btn { padding: 11px 22px; border-radius: 8px; border: none; font-size: 14px; font-weight: 500; cursor: pointer; font-family: var(--font); display: inline-flex; align-items: center; gap: 8px; transition: opacity .15s; }
  .btn:hover { opacity: .85; }
  .btn:active { transform: scale(.97); }
  .btn-primary { background: #1c4a2a; color: #6ee7a0; }
  .btn-ghost { background: transparent; border: 1px solid #2a2a2a; color: #666; }
  .btn-ghost:hover { color: #aaa; border-color: #444; }
  .btn-full { width: 100%; justify-content: center; }
  .status-select { background: #131313; border: 1px solid #2a2a2a; border-radius: 6px; color: #ccc; font-size: 12px; padding: 5px 8px; cursor: pointer; font-family: var(--font); outline: none; }
  .feedback { display: none; padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-top: 0.8rem; }
  .feedback.show { display: block; }
  .feedback.ok  { background: #0f2010; border: 1px solid #1c4a2a; color: #6ee7a0; }
  .feedback.err { background: #2a0f0f; border: 1px solid #4a1c1c; color: #f87171; }
  .user-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .user-table th { text-align: left; padding: 8px 10px; color: #555; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid #1a1a1a; }
  .user-table td { padding: 10px 10px; border-bottom: 1px solid #111; vertical-align: middle; }
  .user-table tr:last-child td { border-bottom: none; }
  .badge { display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 600; }
  .badge-ok { background: #0f2010; color: #6ee7a0; }
  .badge-exp { background: #2a1a0a; color: #fbbf24; }
  .badge-rev { background: #2a0f0f; color: #f87171; }
  .badge-admin { background: #1a1a2a; color: #93c5fd; }
  .empty { text-align: center; padding: 2rem; color: #333; font-size: 13px; }
  .divider { border: none; border-top: 1px solid #1a1a1a; margin: 0; }
  .admin-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-bottom: 0.5rem; }
  .admin-header h1 { font-size: 18px; font-weight: 600; color: #ccc; }
  .btn-voltar { position: fixed; top: 16px; left: 16px; background: rgba(255,255,255,0.05); border: 1px solid #2a2a2a; color: #666; border-radius: 8px; padding: 8px 14px; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; text-decoration: none; }
  .btn-voltar:hover { color: #aaa; border-color: #444; }
</style>
</head>
<body>

<a class="btn-voltar" href="index.html">← Voltar</a>

<div class="logo"><i class="ti ti-shield-lock"></i>&nbsp; Bingo — Administração</div>

<div id="adminLogin">
  <h1>Acesso Administrativo</h1>
  <p>Esta página é restrita ao administrador do sistema.</p>
  <div class="field-group">
    <div>
      <label>Senha do Administrador</label>
      <input type="password" id="adminPass" placeholder="••••••••" />
    </div>
    <button class="btn btn-primary btn-full" id="btnEntrar" onclick="adminLogin()">
      <i class="ti ti-login"></i> Entrar
    </button>
  </div>
  <div class="feedback" id="loginFeedback"></div>
</div>

<div id="adminPanel">
  <div class="admin-header">
    <h1><i class="ti ti-shield-check"></i>&nbsp; Painel do Administrador</h1>
    <button class="btn btn-ghost" onclick="adminLogout()" style="font-size:13px">
      <i class="ti ti-logout"></i> Sair
    </button>
  </div>
  <div class="card">
    <div class="card-title"><i class="ti ti-user-plus"></i> Cadastrar / Renovar Usuário</div>
    <div class="field-group">
      <div class="row-2">
        <div><label>CPF (somente números)</label><input type="tel" id="regCpf" placeholder="00000000000" maxlength="14" /></div>
        <div><label>Nome</label><input type="text" id="regNome" placeholder="Nome completo" /></div>
      </div>
      <div class="row-2">
        <div><label>Senha de acesso</label><input type="password" id="regSenha" placeholder="Mínimo 4 caracteres" /></div>
        <div><label>Confirmar senha</label><input type="password" id="regSenhaConf" placeholder="Repita a senha" /></div>
      </div>
      <button class="btn btn-primary" onclick="registerUser()" id="regBtn">
        <i class="ti ti-cloud-upload"></i> Cadastrar / Renovar (24h)
      </button>
    </div>
    <div class="feedback" id="regFeedback"></div>
  </div>
  <hr class="divider" />
  <div class="card">
    <div class="card-title">
      <i class="ti ti-users"></i> Usuários Cadastrados
      <button class="btn btn-ghost" onclick="loadUsers()" style="font-size:12px;padding:5px 12px;margin-left:auto">
        <i class="ti ti-refresh"></i> Atualizar
      </button>
    </div>
    <div id="userTableWrap"><div class="empty">Faça login para ver os usuários.</div></div>
  </div>
</div>

<script>
const AUTH_URL = 'https://script.google.com/macros/s/AKfycbzKFe9JZI6OwhXlNgoaawy2WyvIKMin19Ke8xkkAXf229eeIHkWlXKz8UdDQ1Y9It-NCg/exec';
function getSenha() { return window.BINGO_PASS || ''; }
function setSenha(v) { window.BINGO_PASS = v; }
async function api(action, extra) {
  const params = Object.assign({ action, admin_password: getSenha() }, extra || {});
  const qs = new URLSearchParams(params).toString();
  try { const r = await fetch(AUTH_URL + '?' + qs); return r.ok ? await r.json() : null; }
  catch(e) { return null; }
}
function feedback(id, type, msg) {
  const el = document.getElementById(id);
  el.className = 'feedback show ' + type;
  el.textContent = msg;
}
async function adminLogin() {
  const pass = document.getElementById('adminPass').value.trim();
  if (!pass) return;
  feedback('loginFeedback', 'ok', 'Verificando...');
  const r = await api('list_users', { admin_password: pass });
  if (!r || !r.ok) { feedback('loginFeedback', 'err', r?.error || 'Acesso negado.'); return; }
  setSenha(pass);
  document.getElementById('adminLogin').style.display = 'none';
  document.getElementById('adminPanel').style.display = 'flex';
  renderUsers(r.users || []);
}
function adminLogout() {
  setSenha('');
  document.getElementById('adminPanel').style.display = 'none';
  document.getElementById('adminLogin').style.display = 'block';
  document.getElementById('adminPass').value = '';
}
async function registerUser() {
  const cpf = document.getElementById('regCpf').value.replace(/\D/g,'').trim();
  const nome = document.getElementById('regNome').value.trim();
  const senha = document.getElementById('regSenha').value.trim();
  const conf = document.getElementById('regSenhaConf').value.trim();
  if (!cpf || cpf.length !== 11) { feedback('regFeedback','err','CPF inválido.'); return; }
  if (!nome) { feedback('regFeedback','err','Informe o nome.'); return; }
  if (!senha || senha.length < 4) { feedback('regFeedback','err','Senha muito curta.'); return; }
  if (senha !== conf) { feedback('regFeedback','err','As senhas não coincidem.'); return; }
  document.getElementById('regBtn').disabled = true;
  feedback('regFeedback','ok','Cadastrando...');
  const r = await api('register', { cpf, nome, password: senha });
  document.getElementById('regBtn').disabled = false;
  if (!r || !r.ok) { feedback('regFeedback','err', r?.error || 'Erro.'); return; }
  feedback('regFeedback','ok', `✓ ${r.nome} ${r.updated?'renovado':'cadastrado'}! Válido até ${r.validade}.`);
  document.getElementById('regCpf').value = '';
  document.getElementById('regNome').value = '';
  document.getElementById('regSenha').value = '';
  document.getElementById('regSenhaConf').value = '';
  loadUsers();
}
async function loadUsers() {
  document.getElementById('userTableWrap').innerHTML = '<div class="empty">Atualizando...</div>';
  const r = await api('list_users');
  if (!r || !r.ok) { document.getElementById('userTableWrap').innerHTML = '<div class="empty">Erro ao carregar.</div>'; return; }
  renderUsers(r.users || []);
}
function fmtData(v) {
  if (!v || v === 'undefined') return '—';
  if (/^\d{2}\/\d{2}\/\d{4}/.test(v)) return v;
  try { const d = new Date(v); return isNaN(d) ? v : d.toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}); }
  catch(e) { return v; }
}
function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function renderUsers(users) {
  const wrap = document.getElementById('userTableWrap');
  if (!users.length) { wrap.innerHTML = '<div class="empty">Nenhum usuário cadastrado.</div>'; return; }
  let h = `<table class="user-table"><thead><tr><th>CPF</th><th>Nome</th><th>Validade</th><th>Status</th><th>Alterar</th></tr></thead><tbody>`;
  users.forEach(u => {
    const bc = u.status==='Ativo'?'badge-ok':u.status==='Expirado'?'badge-exp':u.status==='Admin'?'badge-admin':'badge-rev';
    const cpf = u.cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/,'$1.$2.$3-$4');
    let opts = '';
    if (u.status !== 'Admin') opts += `<option value="promote">→ Admin</option>`;
    if (u.status !== 'Ativo' && u.status !== 'Revogado') opts += `<option value="register">→ Renovar (24h)</option>`;
    if (u.status !== 'Revogado') opts += `<option value="revoke">→ Revogar</option>`;
    if (u.status === 'Admin') opts += `<option value="demote">→ Remover Admin</option>`;
    h += `<tr><td style="font-family:monospace;color:#888">${cpf}</td><td>${esc(u.nome)}</td><td style="color:#555;font-size:12px">${fmtData(u.validade)}</td><td><span class="badge ${bc}">${u.status}</span></td><td><select data-cpf="${u.cpf}" data-nome="${esc(u.nome)}" class="status-select" onchange="aplicarAcao(this)"><option value="">— ação —</option>${opts}</select></td></tr>`;
  });
  h += '</tbody></table>';
  wrap.innerHTML = h;
}
async function aplicarAcao(sel) {
  const action = sel.value; const cpf = sel.getAttribute('data-cpf'); const nome = sel.getAttribute('data-nome');
  if (!action) return;
  const senha = getSenha();
  if (!senha) { alert('Sessão perdida.'); adminLogout(); return; }
  const msgs = { promote:`Promover ${nome} a Admin?`, revoke:`Revogar acesso de ${nome}?`, demote:`Remover Admin de ${nome}?`, register:`Renovar acesso de ${nome} por 24h?` };
  if (!confirm(msgs[action])) { sel.value = ''; return; }
  sel.disabled = true;
  const r = await api(action === 'register' ? 'renew' : action, { cpf });
  sel.disabled = false;
  if (r && r.ok) { loadUsers(); } else { alert(r?.error || 'Erro.'); sel.value = ''; }
}
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && document.getElementById('adminLogin').style.display !== 'none') adminLogin();
});
</script>
</body>
</html>
